# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/master/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta
# Ignore AssetBundles
AssetBundles/
Assets/StreamingAssets/AssetBundles/

# Ignore Addressable Build
ServerData/
# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vscode/
.vsconfig

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.ipa
*.dSYM.zip

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/Android
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/iOS
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/Android.meta
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/iOS.meta

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
/.idea/*

# EDM4U Maven cache
Assets/Firebase/
Assets/Firebase.meta
Assets/Firebase/m2repository/
Assets/Firebase/m2repository.meta
Assets/ExternalDependencyManager/Editor/m2repository/

# Firebase. Ref: https://github.com/firebase/quickstart-unity/issues/554#issuecomment-686876563
Assets/GeneratedLocalRepo/
GeneratedLocalRepo.meta
Assets/StreamingAssets/google-services-desktop.json
Assets/StreamingAssets/google-services-desktop.json.meta
Assets/Plugins/Android/Firebase*

# Crashlytics generated files. Safe to ignore.
# Ref: https://github.com/firebase/quickstart-unity/issues/966#issuecomment-786436810
crashlytics_build_id.xml
crashlytics_unity_version.xml
crashlytics_build_id.xml.meta
crashlytics_unity_version.xml.meta

# Claude Code local settings
.claude/settings.local.json
Assets/UnityMCP/.claude/settings.local.json

# Misc
.DS_Store
remote_config_data
fastlane/README.md
fastlane/report.xml
SmartLibrarySettings/
Assembly-CSharp.csproj.DotSettings
Assets/Custom/BuildReport.meta
ProjectSettings/GvhProjectSettings.xml
ProjectSettings/NickeltinCoreSettings.asset
Assets/_Data/Materials/LoseRenderTexture.renderTexture
Assets/Editor Default Resources/Febucci.meta
Assets/Editor Default Resources/Febucci/HierarchyData.asset
Assets/Editor Default Resources/Febucci/HierarchyData.asset.meta
